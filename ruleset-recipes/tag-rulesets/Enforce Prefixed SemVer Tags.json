{
  "id": 13692713,
  "name": "Enforce Prefixed SemVer Tags",
  "target": "tag",
  "source_type": "Repository",
  "source": "ucm-it/vlad-ruleset-demo",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "exclude": [],
      "include": [
        "~ALL"
      ]
    }
  },
  "rules": [
    {
      "type": "update"
    },
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "tag_name_pattern",
      "parameters": {
        "operator": "regex",
        "pattern": "[a-z-]+\\/v(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?",
        "negate": false,
        "name": "Tag name must match package-prefixed semantic versioning pattern"
      }
    }
  ],
  "bypass_actors": []
}